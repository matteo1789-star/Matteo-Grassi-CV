    lang_title: 'Lingue parlate',
    lang_it: 'Italiano', lang_en: 'Inglese', lang_es: 'Spagnolo',
    lang_native: 'Madrelingua', lang_fluent: 'Fluente · C1', lang_prof: 'Professionale · B2',
    chat_title: 'AI di Matteo',
    chat_status: 'Sempre disponibile',
    chat_welcome: 'Ciao! 👋 Sono l\'assistente AI di Matteo. Chiedimi qualsiasi cosa sulla sua esperienza professionale, competenze o background!',
    chat_placeholder: 'Scrivi un messaggio…',
    footer_text: '© 2026 Matteo Grassi · Tutti i diritti riservati',
    exp: [
      { role: 'Senior Account Director', company: 'LinkedIn Ireland', period: '2020 – Presente', desc: 'Gestione di un portafoglio di clienti enterprise nel mercato italiano. Responsabile dello sviluppo delle soluzioni Talent Solutions e Marketing Solutions, con focus su rinnovi, espansione e nuove opportunità di business.' },
      { role: 'Account Director', company: 'LinkedIn Ireland', period: '2017 – 2020', desc: 'Acquisizione e gestione di account strategici nel segmento Mid-Market. Sviluppo di relazioni commerciali durature con HR director, C-suite e marketing manager.' },
      { role: 'Account Executive', company: 'LinkedIn', period: '2014 – 2017', desc: 'Gestione commerciale di account nel segmento SMB e Mid-Market con focus su prospecting, pipeline management e chiusura contratti.' }
    ],
    skills: [
      { icon: '🎯', name: 'B2B Enterprise Sales', level: 95, label: 'Expert' },
      { icon: '🤝', name: 'Account Management', level: 90, label: 'Expert' },
      { icon: '📊', name: 'Talent Solutions', level: 92, label: 'Expert' },
      { icon: '📣', name: 'Marketing Solutions', level: 85, label: 'Avanzato' },
      { icon: '🔄', name: 'Contract Renewal', level: 88, label: 'Avanzato' },
      { icon: '🌐', name: 'CRM & Pipeline Mgmt', level: 80, label: 'Avanzato' }
    ]
  },
  en: {
    nav_about: 'About',
    nav_exp: 'Experience',
    nav_skills: 'Skills',
    nav_lang: 'Languages',
    hero_tag: 'Senior Account Director',
    hero_subtitle: 'LinkedIn Ireland · Dublin',
    hero_cta1: 'View experience',
    hero_cta2: 'Chat with my AI',
    about_title: 'My profile',
    about_text: 'I\'m <strong>Matteo Grassi</strong>, Senior Account Director at <strong>LinkedIn Ireland</strong>. With over 10 years of B2B sales experience, I specialise in Talent and Marketing Solutions for mid-size and enterprise companies. I speak Italian, English, and Spanish, with a strong international mindset and focus on long-term relationship building.',
    stat_years: 'Years of experience',
    stat_langs: 'Languages spoken',
    stat_sales: 'B2B Sales Expert',
    stat_global: 'Global Mindset',
    exp_title: 'Career path',
    skills_title: 'Key skills',
    lang_title: 'Languages',
    lang_it: 'Italian', lang_en: 'English', lang_es: 'Spanish',
    lang_native: 'Native', lang_fluent: 'Fluent · C1', lang_prof: 'Professional · B2',
    chat_title: 'Matteo\'s AI',
    chat_status: 'Always available',
    chat_welcome: 'Hi! 👋 I\'m Matteo\'s AI assistant. Ask me anything about his professional experience, skills, or background!',
    chat_placeholder: 'Type a message…',
    footer_text: '© 2026 Matteo Grassi · All rights reserved',
    exp: [
      { role: 'Senior Account Director', company: 'LinkedIn Ireland', period: '2020 – Present', desc: 'Managing an enterprise client portfolio in the Italian market. Responsible for Talent Solutions and Marketing Solutions growth, focusing on renewals, expansion, and new business opportunities.' },
      { role: 'Account Director', company: 'LinkedIn Ireland', period: '2017 – 2020', desc: 'Acquisition and management of strategic accounts in the Mid-Market segment. Building lasting commercial relationships with HR directors, C-suite, and marketing managers.' },
      { role: 'Account Executive', company: 'LinkedIn', period: '2014 – 2017', desc: 'Commercial management of SMB and Mid-Market accounts with focus on prospecting, pipeline management, and closing deals.' }
    ],
    skills: [
      { icon: '🎯', name: 'B2B Enterprise Sales', level: 95, label: 'Expert' },
      { icon: '🤝', name: 'Account Management', level: 90, label: 'Expert' },
      { icon: '📊', name: 'Talent Solutions', level: 92, label: 'Expert' },
      { icon: '📣', name: 'Marketing Solutions', level: 85, label: 'Advanced' },
      { icon: '🔄', name: 'Contract Renewal', level: 88, label: 'Advanced' },
      { icon: '🌐', name: 'CRM & Pipeline Mgmt', level: 80, label: 'Advanced' }
    ]
  },
  es: {
    nav_about: 'Sobre mí',
    nav_exp: 'Experiencia',
    nav_skills: 'Habilidades',
    nav_lang: 'Idiomas',
    hero_tag: 'Director de Cuentas Senior',
    hero_subtitle: 'LinkedIn Ireland · Dublín',
    hero_cta1: 'Ver experiencia',
    hero_cta2: 'Habla con mi IA',
    about_title: 'Mi perfil',
    about_text: 'Soy <strong>Matteo Grassi</strong>, Director de Cuentas Senior en <strong>LinkedIn Ireland</strong>. Con más de 10 años de experiencia en ventas B2B, me especializo en soluciones de Talent y Marketing para empresas medianas y grandes. Hablo italiano, inglés y español, con una fuerte mentalidad internacional y enfoque en relaciones comerciales a largo plazo.',
    stat_years: 'Años de experiencia',
    stat_langs: 'Idiomas hablados',
    stat_sales: 'Experto en B2B',
    stat_global: 'Mentalidad global',
    exp_title: 'Trayectoria profesional',
    skills_title: 'Habilidades clave',
    lang_title: 'Idiomas',
    lang_it: 'Italiano', lang_en: 'Inglés', lang_es: 'Español',
    lang_native: 'Lengua materna', lang_fluent: 'Fluido · C1', lang_prof: 'Profesional · B2',
    chat_title: 'IA de Matteo',
    chat_status: 'Siempre disponible',
    chat_welcome: '¡Hola! 👋 Soy el asistente de IA de Matteo. ¡Pregúntame cualquier cosa sobre su experiencia profesional, habilidades o trayectoria!',
    chat_placeholder: 'Escribe un mensaje…',
    footer_text: '© 2026 Matteo Grassi · Todos los derechos reservados',
    exp: [
      { role: 'Director de Cuentas Senior', company: 'LinkedIn Ireland', period: '2020 – Presente', desc: 'Gestión de una cartera de clientes enterprise en el mercado italiano. Responsable del crecimiento de Talent Solutions y Marketing Solutions, con foco en renovaciones, expansión y nuevas oportunidades.' },
      { role: 'Director de Cuentas', company: 'LinkedIn Ireland', period: '2017 – 2020', desc: 'Adquisición y gestión de cuentas estratégicas en el segmento Mid-Market. Construcción de relaciones comerciales duraderas con directores de RRHH, C-suite y responsables de marketing.' },
      { role: 'Account Executive', company: 'LinkedIn', period: '2014 – 2017', desc: 'Gestión comercial de cuentas SMB y Mid-Market con foco en prospección, gestión del pipeline y cierre de contratos.' }
    ],
    skills: [
      { icon: '🎯', name: 'Ventas B2B Enterprise', level: 95, label: 'Experto' },
      { icon: '🤝', name: 'Gestión de Cuentas', level: 90, label: 'Experto' },
      { icon: '📊', name: 'Talent Solutions', level: 92, label: 'Experto' },
      { icon: '📣', name: 'Marketing Solutions', level: 85, label: 'Avanzado' },
      { icon: '🔄', name: 'Renovación de Contratos', level: 88, label: 'Avanzado' },
      { icon: '🌐', name: 'CRM y Pipeline', level: 80, label: 'Avanzado' }
    ]
  }
};

// ── STATE ─────────────────────────────────────────────────
let currentLang = 'it';
let chatOpen = false;
let chatInitialized = false;

// ── RENDER ────────────────────────────────────────────────
function render() {
  const t = i18n[currentLang];

  // Static i18n keys
  document.querySelectorAll('[data-i18n]').forEach(el => {
    const key = el.getAttribute('data-i18n');
    if (t[key] !== undefined) el.innerHTML = t[key];
  });

  // Timeline
  const tl = document.getElementById('timeline');
  tl.innerHTML = t.exp.map(e => `
    <div class="timeline-item">
      <div class="timeline-dot"></div>
      <div class="timeline-card">
        <div class="timeline-header">
          <div>
            <div class="timeline-role">${e.role}</div>
            <div class="timeline-company">${e.company}</div>
          </div>
          <div class="timeline-period">${e.period}</div>
        </div>
        <p class="timeline-desc">${e.desc}</p>
      </div>
    </div>`).join('');

  // Skills
  const sg = document.getElementById('skillsGrid');
  sg.innerHTML = t.skills.map(s => `
    <div class="skill-card">
      <div class="skill-header">
        <div class="skill-icon">${s.icon}</div>
        <div class="skill-name">${s.name}</div>
      </div>
      <div class="skill-bar-bg">
        <div class="skill-bar" style="width:${s.level}%"></div>
      </div>
      <div class="skill-level">${s.label} · ${s.level}%</div>
    </div>`).join('');

  // Chat placeholder
  document.getElementById('chatInput').placeholder = t.chat_placeholder;

  // Update lang buttons
  document.querySelectorAll('.lang-btn').forEach(btn => {
    btn.classList.toggle('active', btn.textContent.toLowerCase() === currentLang);
  });

  // Page title/lang attr
  document.documentElement.lang = currentLang;
}

function setLang(lang) {
  currentLang = lang;
  render();
  // Reset chat welcome on lang change if chat not started
  if (!chatInitialized) return;
}

// ── NAV ──────────────────────────────────────────────────
function toggleMenu() {
  const nl = document.getElementById('navLinks');
  nl.classList.toggle('open');
}
document.querySelectorAll('.nav-links a').forEach(a => {
  a.addEventListener('click', () => {
    document.getElementById('navLinks').classList.remove('open');
  });
});

// ── CHAT ─────────────────────────────────────────────────
function openChat() { chatOpen = false; toggleChat(); }

function toggleChat() {
  chatOpen = !chatOpen;
  const win = document.getElementById('chatWindow');
  win.classList.toggle('open', chatOpen);
  if (chatOpen && !chatInitialized) {
    chatInitialized = true;
    addBotMessage(i18n[currentLang].chat_welcome);
  }
  if (chatOpen) setTimeout(() => document.getElementById('chatInput').focus(), 250);
}

function addBotMessage(text) {
  const msgs = document.getElementById('chatMessages');
  const div = document.createElement('div');
  div.className = 'msg msg-bot';
  div.textContent = text;
  msgs.appendChild(div);
  msgs.scrollTop = msgs.scrollHeight;
}

function addUserMessage(text) {
  const msgs = document.getElementById('chatMessages');
  const div = document.createElement('div');
  div.className = 'msg msg-user';
  div.textContent = text;
  msgs.appendChild(div);
  msgs.scrollTop = msgs.scrollHeight;
}

function addTyping() {
  const msgs = document.getElementById('chatMessages');
  const div = document.createElement('div');
  div.className = 'msg msg-bot msg-typing';
  div.id = 'typing';
  div.innerHTML = '<span></span><span></span><span></span>';
  msgs.appendChild(div);
  msgs.scrollTop = msgs.scrollHeight;
  return div;
}

async function sendMessage() {
  const input = document.getElementById('chatInput');
  const btn = document.getElementById('sendBtn');
  const text = input.value.trim();
  if (!text) return;

  addUserMessage(text);
  input.value = '';
  input.style.height = 'auto';
  btn.disabled = true;

  const typing = addTyping();

  try {
    const res = await fetch('/api/chat', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ message: text, lang: currentLang })
    });
    const data = await res.json();
    typing.remove();
    addBotMessage(data.reply || data.error || 'Errore nella risposta.');
  } catch {
    typing.remove();
    addBotMessage('⚠️ Impossibile connettersi al server. Riprova più tardi.');
  } finally {
    btn.disabled = false;
    input.focus();
  }
}

// ── INIT ──────────────────────────────────────────────────
render();
</script>
</body>
</html>
