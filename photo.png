<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Matteo Grassi — Portfolio</title>
  <meta name="description" content="Portfolio professionale di Matteo Grassi, Senior Account Director at LinkedIn Ireland">
  <style>
    /* ── RESET & BASE ─────────────────────────────────── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --c-bg: #0a0f1e;
      --c-surface: #111827;
      --c-card: #1a2235;
      --c-border: rgba(255,255,255,0.08);
      --c-accent: #0077b5;
      --c-accent2: #00a0dc;
      --c-gold: #f59e0b;
      --c-text: #f1f5f9;
      --c-muted: #94a3b8;
      --c-subtle: #475569;
      --radius: 16px;
      --radius-sm: 8px;
      --shadow: 0 8px 32px rgba(0,0,0,0.4);
      --transition: 0.3s ease;
    }
    html { scroll-behavior: smooth; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;
      background: var(--c-bg);
      color: var(--c-text);
      line-height: 1.6;
      min-height: 100vh;
    }
    a { color: var(--c-accent2); text-decoration: none; }
    a:hover { text-decoration: underline; }
    img { max-width: 100%; display: block; }

    /* ── NAV ──────────────────────────────────────────── */
    .nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 100;
      display: flex; align-items: center; justify-content: space-between;
      padding: 1rem 2rem;
      background: rgba(10,15,30,0.85);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--c-border);
    }
    .nav-logo {
      font-size: 1.1rem; font-weight: 700; color: var(--c-text);
      letter-spacing: -0.02em;
    }
    .nav-logo span { color: var(--c-accent); }
    .nav-links {
      display: flex; align-items: center; gap: 1.5rem;
      list-style: none;
    }
    .nav-links a {
      color: var(--c-muted); font-size: 0.9rem; font-weight: 500;
      transition: color var(--transition);
    }
    .nav-links a:hover { color: var(--c-text); text-decoration: none; }
    .lang-switcher {
      display: flex; gap: 0.4rem;
    }
    .lang-btn {
      padding: 0.25rem 0.6rem; border-radius: 20px; font-size: 0.78rem;
      font-weight: 600; cursor: pointer; border: 1px solid var(--c-border);
      background: transparent; color: var(--c-muted);
      transition: all var(--transition); text-transform: uppercase;
    }
    .lang-btn.active, .lang-btn:hover {
      background: var(--c-accent); border-color: var(--c-accent);
      color: #fff;
    }
    .hamburger {
      display: none; flex-direction: column; gap: 5px;
      cursor: pointer; padding: 4px;
    }
    .hamburger span {
      display: block; width: 24px; height: 2px;
      background: var(--c-text); border-radius: 2px;
      transition: all var(--transition);
    }

    /* ── HERO ─────────────────────────────────────────── */
    .hero {
      min-height: 100vh;
      display: flex; align-items: center; justify-content: center;
      padding: 7rem 2rem 4rem;
      position: relative; overflow: hidden;
    }
    .hero::before {
      content: '';
      position: absolute; inset: 0;
      background: radial-gradient(ellipse 80% 60% at 50% 30%, rgba(0,119,181,0.15) 0%, transparent 70%);
      pointer-events: none;
    }
    .hero-inner {
      max-width: 900px; width: 100%;
      display: flex; align-items: center; gap: 4rem;
    }
    .hero-photo-wrap {
      flex-shrink: 0;
    }
    .hero-photo {
      width: 180px; height: 180px;
      border-radius: 50%;
      object-fit: cover;
      border: 3px solid var(--c-accent);
      box-shadow: 0 0 40px rgba(0,119,181,0.35);
    }
    .hero-photo-placeholder {
      width: 180px; height: 180px; border-radius: 50%;
      background: var(--c-card);
      border: 3px solid var(--c-accent);
      box-shadow: 0 0 40px rgba(0,119,181,0.35);
      display: flex; align-items: center; justify-content: center;
      font-size: 4rem; color: var(--c-muted);
    }
    .hero-content { flex: 1; }
    .hero-tag {
      display: inline-block; padding: 0.3rem 0.8rem;
      background: rgba(0,119,181,0.15); border: 1px solid rgba(0,119,181,0.3);
      border-radius: 20px; font-size: 0.78rem; font-weight: 600;
      color: var(--c-accent2); margin-bottom: 1rem; text-transform: uppercase;
      letter-spacing: 0.08em;
    }
    .hero-name {
      font-size: clamp(2rem, 5vw, 3.2rem);
      font-weight: 800; line-height: 1.1;
      letter-spacing: -0.03em;
      margin-bottom: 0.5rem;
    }
    .hero-title {
      font-size: 1.1rem; color: var(--c-muted);
      font-weight: 400; margin-bottom: 1.5rem;
    }
    .hero-contacts {
      display: flex; flex-wrap: wrap; gap: 0.75rem;
      margin-bottom: 1.5rem;
    }
    .contact-chip {
      display: flex; align-items: center; gap: 0.5rem;
      padding: 0.5rem 1rem;
      background: var(--c-card); border: 1px solid var(--c-border);
      border-radius: 30px; font-size: 0.85rem; color: var(--c-text);
      transition: all var(--transition);
    }
    .contact-chip:hover {
      border-color: var(--c-accent2); color: var(--c-accent2);
      text-decoration: none; transform: translateY(-1px);
    }
    .contact-chip svg { width: 16px; height: 16px; flex-shrink: 0; }
    .hero-cta {
      display: flex; flex-wrap: wrap; gap: 0.75rem;
    }
    .btn {
      display: inline-flex; align-items: center; gap: 0.5rem;
      padding: 0.75rem 1.5rem; border-radius: 30px;
      font-size: 0.9rem; font-weight: 600; cursor: pointer;
      transition: all var(--transition); border: none;
    }
    .btn-primary {
      background: var(--c-accent); color: #fff;
    }
    .btn-primary:hover { background: var(--c-accent2); text-decoration: none; transform: translateY(-2px); box-shadow: 0 8px 20px rgba(0,119,181,0.4); }
    .btn-outline {
      background: transparent; color: var(--c-text);
      border: 1px solid var(--c-border);
    }
    .btn-outline:hover { border-color: var(--c-accent2); color: var(--c-accent2); text-decoration: none; transform: translateY(-2px); }

    /* ── SECTIONS ─────────────────────────────────────── */
    section { padding: 5rem 2rem; }
    .section-inner { max-width: 900px; margin: 0 auto; }
    .section-label {
      font-size: 0.75rem; font-weight: 700; color: var(--c-accent2);
      text-transform: uppercase; letter-spacing: 0.12em;
      margin-bottom: 0.5rem;
    }
    .section-title {
      font-size: clamp(1.6rem, 4vw, 2.4rem);
      font-weight: 800; letter-spacing: -0.02em;
      margin-bottom: 1rem;
    }
    .section-divider {
      width: 48px; height: 3px;
      background: linear-gradient(90deg, var(--c-accent), var(--c-accent2));
      border-radius: 2px; margin-bottom: 2.5rem;
    }

    /* ── ABOUT ────────────────────────────────────────── */
    .about-grid {
      display: grid; grid-template-columns: 1fr 1fr;
      gap: 2rem; margin-top: 2rem;
    }
    .about-text { font-size: 1rem; color: var(--c-muted); line-height: 1.8; }
    .about-text strong { color: var(--c-text); }
    .about-stats {
      display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;
    }
    .stat-card {
      background: var(--c-card); border: 1px solid var(--c-border);
      border-radius: var(--radius); padding: 1.5rem;
      text-align: center; transition: all var(--transition);
    }
    .stat-card:hover { border-color: var(--c-accent2); transform: translateY(-2px); }
    .stat-number {
      font-size: 2rem; font-weight: 800;
      background: linear-gradient(135deg, var(--c-accent), var(--c-accent2));
      -webkit-background-clip: text; -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .stat-label { font-size: 0.8rem; color: var(--c-muted); margin-top: 0.25rem; }

    /* ── EXPERIENCE ───────────────────────────────────── */
    .timeline { position: relative; padding-left: 2rem; }
    .timeline::before {
      content: ''; position: absolute; left: 0; top: 0; bottom: 0;
      width: 2px;
      background: linear-gradient(180deg, var(--c-accent), transparent);
    }
    .timeline-item {
      position: relative; margin-bottom: 2.5rem;
    }
    .timeline-dot {
      position: absolute; left: -2.45rem; top: 0.35rem;
      width: 14px; height: 14px; border-radius: 50%;
      background: var(--c-accent);
      border: 2px solid var(--c-bg);
      box-shadow: 0 0 0 3px rgba(0,119,181,0.3);
    }
    .timeline-card {
      background: var(--c-card); border: 1px solid var(--c-border);
      border-radius: var(--radius); padding: 1.5rem;
      transition: all var(--transition);
    }
    .timeline-card:hover { border-color: var(--c-accent2); transform: translateX(4px); }
    .timeline-header {
      display: flex; align-items: flex-start; justify-content: space-between;
      gap: 1rem; margin-bottom: 0.5rem; flex-wrap: wrap;
    }
    .timeline-role { font-size: 1.05rem; font-weight: 700; }
    .timeline-company { color: var(--c-accent2); font-size: 0.9rem; }
    .timeline-period {
      font-size: 0.78rem; color: var(--c-muted);
      background: var(--c-surface); border: 1px solid var(--c-border);
      padding: 0.25rem 0.7rem; border-radius: 20px; white-space: nowrap;
    }
    .timeline-desc { font-size: 0.9rem; color: var(--c-muted); line-height: 1.7; }

    /* ── SKILLS ───────────────────────────────────────── */
    .skills-grid {
      display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
      gap: 1.25rem;
    }
    .skill-card {
      background: var(--c-card); border: 1px solid var(--c-border);
      border-radius: var(--radius); padding: 1.25rem;
      transition: all var(--transition);
    }
    .skill-card:hover { border-color: var(--c-accent2); transform: translateY(-2px); }
    .skill-header {
      display: flex; align-items: center; gap: 0.75rem;
      margin-bottom: 0.75rem;
    }
    .skill-icon {
      width: 36px; height: 36px; border-radius: var(--radius-sm);
      background: rgba(0,119,181,0.15);
      display: flex; align-items: center; justify-content: center;
      font-size: 1.2rem;
    }
    .skill-name { font-size: 0.95rem; font-weight: 600; }
    .skill-bar-bg {
      height: 4px; background: var(--c-surface); border-radius: 2px; overflow: hidden;
    }
    .skill-bar {
      height: 100%; border-radius: 2px;
      background: linear-gradient(90deg, var(--c-accent), var(--c-accent2));
      transition: width 1s ease;
    }
    .skill-level { font-size: 0.75rem; color: var(--c-muted); margin-top: 0.4rem; }

    /* ── LANGUAGES ────────────────────────────────────── */
    .lang-grid {
      display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
      gap: 1.25rem;
    }
    .lang-card {
      background: var(--c-card); border: 1px solid var(--c-border);
      border-radius: var(--radius); padding: 1.5rem; text-align: center;
      transition: all var(--transition);
    }
    .lang-card:hover { border-color: var(--c-accent2); transform: translateY(-3px); }
    .lang-flag { font-size: 2.5rem; margin-bottom: 0.5rem; }
    .lang-name { font-size: 1rem; font-weight: 700; margin-bottom: 0.25rem; }
    .lang-level {
      font-size: 0.78rem; color: var(--c-muted);
      background: rgba(0,119,181,0.1); border-radius: 20px;
      padding: 0.2rem 0.7rem; display: inline-block;
    }
    .lang-dots { display: flex; justify-content: center; gap: 4px; margin-top: 0.75rem; }
    .lang-dot {
      width: 8px; height: 8px; border-radius: 50%;
      background: var(--c-border);
    }
    .lang-dot.filled { background: var(--c-accent); }

    /* ── CHAT WIDGET ──────────────────────────────────── */
    .chat-fab {
      position: fixed; bottom: 2rem; right: 2rem; z-index: 200;
      width: 56px; height: 56px; border-radius: 50%;
      background: linear-gradient(135deg, var(--c-accent), var(--c-accent2));
      border: none; cursor: pointer; color: #fff;
      box-shadow: 0 4px 20px rgba(0,119,181,0.5);
      display: flex; align-items: center; justify-content: center;
      transition: all var(--transition);
      animation: pulse 3s infinite;
    }
    .chat-fab:hover { transform: scale(1.1); box-shadow: 0 8px 30px rgba(0,119,181,0.7); }
    @keyframes pulse {
      0%, 100% { box-shadow: 0 4px 20px rgba(0,119,181,0.5); }
      50% { box-shadow: 0 4px 30px rgba(0,160,220,0.8); }
    }
    .chat-fab svg { width: 24px; height: 24px; }
    .chat-window {
      position: fixed; bottom: 5.5rem; right: 2rem; z-index: 200;
      width: min(380px, calc(100vw - 2rem));
      background: var(--c-surface); border: 1px solid var(--c-border);
      border-radius: var(--radius); box-shadow: var(--shadow);
      display: flex; flex-direction: column;
      max-height: 520px; overflow: hidden;
      transform: scale(0.9) translateY(20px); opacity: 0;
      pointer-events: none;
      transition: all 0.25s cubic-bezier(0.34,1.56,0.64,1);
    }
    .chat-window.open {
      transform: scale(1) translateY(0); opacity: 1;
      pointer-events: all;
    }
    .chat-header {
      padding: 1rem 1.25rem;
      background: linear-gradient(135deg, var(--c-accent), var(--c-accent2));
      display: flex; align-items: center; gap: 0.75rem;
    }
    .chat-header-avatar {
      width: 36px; height: 36px; border-radius: 50%;
      background: rgba(255,255,255,0.2);
      display: flex; align-items: center; justify-content: center;
      font-size: 1.2rem;
    }
    .chat-header-info { flex: 1; }
    .chat-header-name { font-size: 0.9rem; font-weight: 700; }
    .chat-header-status { font-size: 0.72rem; opacity: 0.85; }
    .chat-close {
      background: none; border: none; color: #fff; cursor: pointer;
      padding: 4px; border-radius: 4px; opacity: 0.8;
      transition: opacity var(--transition);
    }
    .chat-close:hover { opacity: 1; }
    .chat-messages {
      flex: 1; overflow-y: auto; padding: 1rem;
      display: flex; flex-direction: column; gap: 0.75rem;
      min-height: 0;
    }
    .chat-messages::-webkit-scrollbar { width: 4px; }
    .chat-messages::-webkit-scrollbar-thumb { background: var(--c-border); border-radius: 2px; }
    .msg {
      max-width: 82%; padding: 0.65rem 0.9rem;
      border-radius: 12px; font-size: 0.85rem; line-height: 1.5;
      word-break: break-word;
    }
    .msg-bot {
      background: var(--c-card); color: var(--c-text);
      border-radius: 4px 12px 12px 12px; align-self: flex-start;
    }
    .msg-user {
      background: var(--c-accent); color: #fff;
      border-radius: 12px 4px 12px 12px; align-self: flex-end;
    }
    .msg-typing {
      display: flex; gap: 5px; align-items: center;
      padding: 0.65rem 0.9rem;
    }
    .msg-typing span {
      width: 7px; height: 7px; border-radius: 50%;
      background: var(--c-muted);
      animation: bounce 1.2s infinite;
    }
    .msg-typing span:nth-child(2) { animation-delay: 0.2s; }
    .msg-typing span:nth-child(3) { animation-delay: 0.4s; }
    @keyframes bounce {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-5px); }
    }
    .chat-input-area {
      display: flex; gap: 0.5rem; padding: 0.75rem;
      border-top: 1px solid var(--c-border);
    }
    .chat-input {
      flex: 1; background: var(--c-card); border: 1px solid var(--c-border);
      border-radius: var(--radius-sm); padding: 0.6rem 0.85rem;
      color: var(--c-text); font-size: 0.85rem;
      resize: none; outline: none; font-family: inherit;
      transition: border-color var(--transition);
    }
    .chat-input:focus { border-color: var(--c-accent); }
    .chat-send {
      width: 38px; height: 38px; border-radius: var(--radius-sm);
      background: var(--c-accent); border: none; color: #fff;
      cursor: pointer; display: flex; align-items: center; justify-content: center;
      transition: all var(--transition); flex-shrink: 0;
    }
    .chat-send:hover { background: var(--c-accent2); transform: scale(1.05); }
    .chat-send:disabled { opacity: 0.5; cursor: not-allowed; }

    /* ── FOOTER ───────────────────────────────────────── */
    footer {
      padding: 2rem; text-align: center;
      border-top: 1px solid var(--c-border);
      font-size: 0.82rem; color: var(--c-subtle);
    }

    /* ── MOBILE ───────────────────────────────────────── */
    @media (max-width: 768px) {
      .nav { padding: 0.85rem 1.25rem; }
      .nav-links { display: none; flex-direction: column; position: fixed;
        top: 60px; left: 0; right: 0; background: var(--c-surface);
        border-bottom: 1px solid var(--c-border); padding: 1rem 1.5rem 1.5rem;
        gap: 1rem;
      }
      .nav-links.open { display: flex; }
      .hamburger { display: flex; }
      .hero-inner { flex-direction: column; align-items: center; text-align: center; gap: 2rem; }
      .hero-photo, .hero-photo-placeholder { width: 140px; height: 140px; }
      .hero-contacts { justify-content: center; }
      .hero-cta { justify-content: center; }
      .about-grid { grid-template-columns: 1fr; }
      .about-stats { grid-template-columns: 1fr 1fr; }
      .chat-window { right: 1rem; bottom: 5rem; width: calc(100vw - 2rem); }
      .chat-fab { bottom: 1.25rem; right: 1.25rem; }
      section { padding: 3.5rem 1.25rem; }
    }
    @media (max-width: 480px) {
      .about-stats { grid-template-columns: 1fr 1fr; }
      .skills-grid { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>

<!-- ── NAV ──────────────────────────────────────────── -->
<nav class="nav">
  <div class="nav-logo">M<span>.</span>Grassi</div>
  <ul class="nav-links" id="navLinks">
    <li><a href="#about" data-i18n="nav_about">Chi sono</a></li>
    <li><a href="#experience" data-i18n="nav_exp">Esperienza</a></li>
    <li><a href="#skills" data-i18n="nav_skills">Competenze</a></li>
    <li><a href="#languages" data-i18n="nav_lang">Lingue</a></li>
    <div class="lang-switcher">
      <button class="lang-btn active" onclick="setLang('it')">IT</button>
      <button class="lang-btn" onclick="setLang('en')">EN</button>
      <button class="lang-btn" onclick="setLang('es')">ES</button>
    </div>
  </ul>
  <div class="hamburger" id="hamburger" onclick="toggleMenu()">
    <span></span><span></span><span></span>
  </div>
</nav>

<!-- ── HERO ─────────────────────────────────────────── -->
<section class="hero" id="home">
  <div class="hero-inner">
    <div class="hero-photo-wrap">
      <img id="heroPhoto" class="hero-photo" src="/photo.png" alt="Matteo Grassi"
           onerror="this.style.display='none'; document.getElementById('heroPlaceholder').style.display='flex'">
      <div class="hero-photo-placeholder" id="heroPlaceholder" style="display:none">👤</div>
    </div>
    <div class="hero-content">
      <div class="hero-tag" data-i18n="hero_tag">Senior Account Director</div>
      <h1 class="hero-name">Matteo Grassi</h1>
      <p class="hero-title" data-i18n="hero_subtitle">LinkedIn Ireland · Dublin</p>
      <div class="hero-contacts">
        <a href="tel:+3530892334107" class="contact-chip">
          <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
          +353 089 233 4107
        </a>
        <a href="mailto:matteo1789@gmail.com" class="contact-chip">
          <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
          matteo1789@gmail.com
        </a>
        <a href="https://linkedin.com/in/matteo-grassi" target="_blank" class="contact-chip">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6zM2 9h4v12H2z"/><circle cx="4" cy="4" r="2"/></svg>
          LinkedIn
        </a>
      </div>
      <div class="hero-cta">
        <a href="#experience" class="btn btn-primary" data-i18n="hero_cta1">Vedi esperienza</a>
        <button class="btn btn-outline" onclick="openChat()" data-i18n="hero_cta2">Chatta con la mia AI</button>
      </div>
    </div>
  </div>
</section>

<!-- ── ABOUT ─────────────────────────────────────────── -->
<section id="about" style="background: var(--c-surface);">
  <div class="section-inner">
    <div class="section-label" data-i18n="nav_about">Chi sono</div>
    <h2 class="section-title" data-i18n="about_title">Il mio profilo</h2>
    <div class="section-divider"></div>
    <div class="about-grid">
      <div>
        <p class="about-text" data-i18n="about_text"></p>
      </div>
      <div class="about-stats">
        <div class="stat-card">
          <div class="stat-number">10+</div>
          <div class="stat-label" data-i18n="stat_years">Anni di esperienza</div>
        </div>
        <div class="stat-card">
          <div class="stat-number">3</div>
          <div class="stat-label" data-i18n="stat_langs">Lingue parlate</div>
        </div>
        <div class="stat-card">
          <div class="stat-number">B2B</div>
          <div class="stat-label" data-i18n="stat_sales">Sales Expert</div>
        </div>
        <div class="stat-card">
          <div class="stat-number">🌍</div>
          <div class="stat-label" data-i18n="stat_global">Global Mindset</div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ── EXPERIENCE ─────────────────────────────────────── -->
<section id="experience">
  <div class="section-inner">
    <div class="section-label" data-i18n="nav_exp">Esperienza</div>
    <h2 class="section-title" data-i18n="exp_title">Percorso professionale</h2>
    <div class="section-divider"></div>
    <div class="timeline" id="timeline"></div>
  </div>
</section>

<!-- ── SKILLS ─────────────────────────────────────────── -->
<section id="skills" style="background: var(--c-surface);">
  <div class="section-inner">
    <div class="section-label" data-i18n="nav_skills">Competenze</div>
    <h2 class="section-title" data-i18n="skills_title">Competenze chiave</h2>
    <div class="section-divider"></div>
    <div class="skills-grid" id="skillsGrid"></div>
  </div>
</section>

<!-- ── LANGUAGES ─────────────────────────────────────── -->
<section id="languages">
  <div class="section-inner">
    <div class="section-label" data-i18n="nav_lang">Lingue</div>
    <h2 class="section-title" data-i18n="lang_title">Lingue parlate</h2>
    <div class="section-divider"></div>
    <div class="lang-grid">
      <div class="lang-card">
        <div class="lang-flag">🇮🇹</div>
        <div class="lang-name" data-i18n="lang_it">Italiano</div>
        <div class="lang-level" data-i18n="lang_native">Madrelingua</div>
        <div class="lang-dots">
          <div class="lang-dot filled"></div><div class="lang-dot filled"></div>
          <div class="lang-dot filled"></div><div class="lang-dot filled"></div>
          <div class="lang-dot filled"></div>
        </div>
      </div>
      <div class="lang-card">
        <div class="lang-flag">🇬🇧</div>
        <div class="lang-name" data-i18n="lang_en">Inglese</div>
        <div class="lang-level" data-i18n="lang_fluent">Fluente / C1</div>
        <div class="lang-dots">
          <div class="lang-dot filled"></div><div class="lang-dot filled"></div>
          <div class="lang-dot filled"></div><div class="lang-dot filled"></div>
          <div class="lang-dot"></div>
        </div>
      </div>
      <div class="lang-card">
        <div class="lang-flag">🇪🇸</div>
        <div class="lang-name" data-i18n="lang_es">Spagnolo</div>
        <div class="lang-level" data-i18n="lang_prof">Professionale / B2</div>
        <div class="lang-dots">
          <div class="lang-dot filled"></div><div class="lang-dot filled"></div>
          <div class="lang-dot filled"></div><div class="lang-dot"></div>
          <div class="lang-dot"></div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ── FOOTER ─────────────────────────────────────────── -->
<footer>
  <p data-i18n="footer_text">© 2026 Matteo Grassi · Tutti i diritti riservati</p>
</footer>

<!-- ── CHAT WIDGET ────────────────────────────────────── -->
<button class="chat-fab" id="chatFab" onclick="toggleChat()" title="Chatta con l'AI">
  <svg fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
    <path stroke-linecap="round" stroke-linejoin="round"
      d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
  </svg>
</button>

<div class="chat-window" id="chatWindow">
  <div class="chat-header">
    <div class="chat-header-avatar">🤖</div>
    <div class="chat-header-info">
      <div class="chat-header-name" data-i18n="chat_title">AI di Matteo</div>
      <div class="chat-header-status" data-i18n="chat_status">Sempre disponibile</div>
    </div>
    <button class="chat-close" onclick="toggleChat()">
      <svg width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
      </svg>
    </button>
  </div>
  <div class="chat-messages" id="chatMessages"></div>
  <div class="chat-input-area">
    <textarea class="chat-input" id="chatInput" rows="1"
      placeholder="Scrivi un messaggio…"
      onkeydown="if(event.key==='Enter'&&!event.shiftKey){event.preventDefault();sendMessage()}"
      oninput="this.style.height='auto';this.style.height=Math.min(this.scrollHeight,100)+'px'">
    </textarea>
    <button class="chat-send" id="sendBtn" onclick="sendMessage()">
      <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/>
      </svg>
    </button>
  </div>
</div>

<!-- ── SCRIPTS ─────────────────────────────────────────── -->
<script>
// ── TRANSLATIONS ─────────────────────────────────────────
const i18n = {
  it: {
    nav_about: 'Chi sono',
    nav_exp: 'Esperienza',
    nav_skills: 'Competenze',
    nav_lang: 'Lingue',
    hero_tag: 'Senior Account Director',
    hero_subtitle: 'LinkedIn Ireland · Dublin',
    hero_cta1: 'Vedi esperienza',
    hero_cta2: 'Chatta con la mia AI',
    about_title: 'Il mio profilo',
    about_text: 'Sono <strong>Matteo Grassi</strong>, Senior Account Director presso <strong>LinkedIn Ireland</strong>. Con oltre 10 anni di esperienza nel B2B sales, mi specializzo nelle soluzioni Talent e Marketing per aziende di medie e grandi dimensioni. Parlo italiano, inglese e spagnolo e ho una forte attitudine al lavoro internazionale e alla costruzione di relazioni a lungo termine.',
    stat_years: 'Anni di esperienza',
    stat_langs: 'Lingue parlate',
    stat_sales: 'Esperto B2B',
    stat_global: 'Mentalità globale',
    exp_title: 'Percorso professionale',
